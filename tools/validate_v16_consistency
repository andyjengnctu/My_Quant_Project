    print("\n================================================================================")
    print("一致性驗證摘要")
    print("================================================================================")
    print(f"驗證股票: {', '.join(selected_tickers)}")
    print(f"總檢查數: {len(df_results)}")
    print(f"失敗數: {len(df_failed)}")
    print(f"CSV 報告: {csv_path}")
    print(f"Excel 報告: {xlsx_path}")

    if not df_summary.empty:
        print("\n各股票摘要：")
        show_cols = [
            "ticker",
            "sanitize_dropped",
            "sanitize_invalid",
            "sanitize_duplicate",
            "single_trade_count",
            "portfolio_trade_count",
            "open_position_exists"
        ]
        print(df_summary[show_cols].to_string(index=False))

    if not df_failed.empty:
        print("\n失敗項目摘要：")
        show_cols = ["ticker", "module", "metric", "expected", "actual", "abs_diff", "note"]
        print(df_failed[show_cols].to_string(index=False))
    else:
        print("\n失敗項目摘要：無")


def resolve_target_tickers():
    available_tickers = discover_available_tickers()
    if not available_tickers:
        raise ValueError(f"{DATA_DIR} 下沒有可用 CSV")

    default_auto = select_sample_tickers(
        available_tickers,
        sample_size=DEFAULT_SAMPLE_SIZE,
        priority_tickers=DEFAULT_PRIORITY_TICKERS
    )

    print(f"可用股票總數: {len(available_tickers)}")
    print(f"預設自動抽樣: {', '.join(default_auto)}")

    raw = input(
        "請輸入股票代號（逗號分隔）；直接 Enter 使用預設抽樣；"
        "或輸入 AUTO:8 代表自動抽 8 檔: "
    ).strip()

    if not raw:
        return default_auto

    raw_upper = raw.upper()
    if raw_upper.startswith("AUTO"):
        sample_size = DEFAULT_SAMPLE_SIZE
        if ":" in raw_upper:
            _, right = raw_upper.split(":", 1)
            try:
                sample_size = max(1, int(right.strip()))
            except ValueError:
                raise ValueError(f"AUTO 樣本數格式錯誤: {raw}")
        return select_sample_tickers(
            available_tickers,
            sample_size=sample_size,
            priority_tickers=DEFAULT_PRIORITY_TICKERS
        )

    tickers = [t.strip() for t in raw.split(",") if t.strip()]
    missing = [t for t in tickers if t not in available_tickers]
    if missing:
        raise ValueError(f"下列股票找不到對應 CSV: {missing}")

    return tickers


def main():
    os.makedirs(OUTPUT_DIR, exist_ok=True)

    base_params = load_params()
    selected_tickers = resolve_target_tickers()

    all_results = []
    summaries = []

    for idx, ticker in enumerate(selected_tickers, start=1):
        print(f"\n[{idx}/{len(selected_tickers)}] 開始驗證: {ticker}")
        try:
            results, summary = validate_one_ticker(ticker, base_params)
            all_results.extend(results)
            summaries.append(summary)
        except Exception as e:
            all_results.append({
                "ticker": ticker,
                "module": "system",
                "metric": "validation_runtime",
                "expected": "成功執行",
                "actual": f"{type(e).__name__}: {e}",
                "abs_diff": None,
                "passed": False,
                "note": "驗證腳本執行失敗，先處理這個錯誤。"
            })

    df_results = pd.DataFrame(all_results)
    df_summary = pd.DataFrame(summaries)
    df_failed = df_results[df_results["passed"] == False].copy() if not df_results.empty else pd.DataFrame()

    if not df_failed.empty:
        df_failed = df_failed.sort_values(by=["ticker", "module", "metric"]).reset_index(drop=True)

    df_by_module, df_by_ticker = build_summary_tables(df_results)

    timestamp = time.strftime("%Y%m%d_%H%M%S")
    csv_path = os.path.join(OUTPUT_DIR, f"v16_consistency_report_{timestamp}.csv")
    df_results.to_csv(csv_path, index=False, encoding="utf-8-sig")

    xlsx_path = write_excel_report(
        df_results=df_results,
        df_failed=df_failed,
        df_summary=df_summary,
        df_by_module=df_by_module,
        df_by_ticker=df_by_ticker,
        timestamp=timestamp
    )

    print_console_summary(
        df_results=df_results,
        df_failed=df_failed,
        df_summary=df_summary,
        selected_tickers=selected_tickers,
        csv_path=csv_path,
        xlsx_path=xlsx_path
    )


if __name__ == "__main__":
    main()